# ══════════════════════════════════════════════════════
#  SMC BOT — Variables de entorno
#  Copia este archivo a .env y completa tus valores.
#  NUNCA subas .env a Git.
# ══════════════════════════════════════════════════════

# ── Binance API ───────────────────────────────────────
# Obtén tus keys en https://testnet.binancefuture.com (testnet)
# o en https://www.binance.com/es/my/settings/api-management (real)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Modo ──────────────────────────────────────────────
# true  = Testnet (dinero ficticio, para pruebas)
# false = Real    (¡cuidado!)
TESTNET=true

# ── Trading ───────────────────────────────────────────
SYMBOL=BTCUSDT
TIMEFRAME=15m
LEVERAGE=2

# ── Gestión de riesgo ─────────────────────────────────
RISK_PER_TRADE=0.01       # 1% del capital por operación
TP_RR_RATIO=2.0           # Ratio riesgo:recompensa (1:2)
ATR_MULTIPLIER=1.5        # Distancia SL en múltiplos de ATR
MAX_OPEN_TRADES=1         # Máximo de posiciones abiertas simultáneas
MAX_DAILY_LOSS=0.03       # Stop trading si pérdida diaria supera 3%

# ── Estrategia SMC ────────────────────────────────────
SCORE_MINIMO=50
SWING_LENGTH=5
FVG_LOOKBACK=30
OB_LOOKBACK=30
OB_MOVE_THRESHOLD=0.004
ATR_PERIOD=14
CANDLES_LIMIT=200
FILTRO_SESION=true
SESIONES_ACTIVAS=london,new_york  # opciones: london, new_york, asia

# ── Backtest ──────────────────────────────────────────
BACKTEST_DIAS=90
BACKTEST_CAPITAL=1000.0
COMISION_PCT=0.0004       # 0.04% por lado (Binance Futures Maker)

# ── Notificaciones Telegram (opcional) ───────────────
# Guía: https://core.telegram.org/bots#how-do-i-create-a-bot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR

# ── Multi-Timeframe (Fase 3) ─────────────────────────────
MTF_ENABLED=true
MTF_HTF=1h              # Timeframe alto para contexto estructural
MTF_LTF=5m              # Timeframe bajo para entrada precisa
MTF_HTF_CANDLES=200
MTF_LTF_CANDLES=100
MTF_BONUS_ALINEADO=20   # Puntos extra si HTF y LTF alineados
MTF_PENALTI_OPUESTO=30  # Puntos a restar si HTF opuesto a LTF

# ── WebSocket (Fase 3) ───────────────────────────────────
WS_ENABLED=true         # false = usar polling REST clásico
WS_RECONNECT_SECS=5     # Segundos base para reconexión
WS_MAX_RECONNECTS=10    # Máximo de intentos antes de parar

# ── Dashboard (Opción A: VPS con nginx) ──────────────────
# No requiere variables extra, solo correr setup_dashboard.sh

# ── Dashboard (Opción B: Cloudflare Pages) ───────────────
# 1. Crear token en: https://dash.cloudflare.com/profile/api-tokens
#    Permiso requerido: "Cloudflare Pages: Edit"
# 2. Account ID en: https://dash.cloudflare.com (barra lateral)
# 3. Crear proyecto en Pages → "Direct Upload" → nombre: smc-bot
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_PROJECT_NAME=smc-bot
