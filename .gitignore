# ══════════════════════════════════════════════
#  .gitignore — SMC Futures Bot
# ══════════════════════════════════════════════

# ── CREDENCIALES — NUNCA COMMITEAR ───────────
.env
.env*
*.env
.env.local
.env.*.local
secrets.py
credentials.py

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ── Entornos virtuales ────────────────────────
venv/
.venv/
env/
ENV/
.virtualenv/

# ── IDEs ─────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────
logs/
*.log

# ── Resultados de backtest ────────────────────
backtest/results/*.json
backtest/results/*.csv
# (mantener solo el directorio vacío con .gitkeep)

# ── Datos descargados ─────────────────────────
data/cache/
data/historical/
*.parquet
*.feather

# ── Jupyter ───────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Pytest / Coverage ─────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Mypy ─────────────────────────────────────
.mypy_cache/

# Deploy
logs/monitor.log
logs/update.log
deploy/*.log
