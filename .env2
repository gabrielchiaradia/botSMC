# ══════════════════════════════════════════════════════
#  SMC BOT — Variables de entorno
#  Copia este archivo a .env y completa tus valores.
#  NUNCA subas .env a Git.
# ══════════════════════════════════════════════════════

# ── Binance API ───────────────────────────────────────
# Obtén tus keys en https://testnet.binancefuture.com (testnet)
# o en https://www.binance.com/es/my/settings/api-management (real)
BINANCE_API_KEY=2g4gmyw52Yhn3OsYvmH0GW36NolYxbTZlYl46l3eIhKTprGgVyWSybNBj7FX4cDH
BINANCE_API_SECRET=lvOQ06732kx8gqPyf7sMUlGEhMBtHDA7wMoUtnW14ZywnY5FG0Je6MXvbwVxJrBc

# ── Modo ──────────────────────────────────────────────
# true  = Testnet (dinero ficticio, para pruebas)
# false = Real    (¡cuidado!)
TESTNET=true

# ── Trading ───────────────────────────────────────────
SYMBOL=ETHUSDT
TIMEFRAME=1h
LEVERAGE=3
TRADING_WINDOWS=
BOT_TAG=1h-aggro-no-filter

# ── Gestión de riesgo ─────────────────────────────────
# 1% del capital por operación
RISK_PER_TRADE=0.01
# Ratio riesgo:recompensa (1:2)
TP_RR_RATIO=2.5
# Distancia SL en múltiplos de ATR
ATR_MULTIPLIER=1.5
# Máximo de posiciones abiertas simultáneas
MAX_OPEN_TRADES=3
# Stop trading si pérdida diaria supera 3%
MAX_DAILY_LOSS=0.03       
BOT_CAPITAL=500

# ── Estrategia SMC ────────────────────────────────────
SCORE_MINIMO=50
SWING_LENGTH=5
FVG_LOOKBACK=30
OB_LOOKBACK=30
OB_MOVE_THRESHOLD=0.004
ATR_PERIOD=14
CANDLES_LIMIT=200
FILTRO_SESION=false
OB_MAX_AGE=30
# opciones: london, new_york, asia
SESIONES_ACTIVAS=  

# ── Backtest ──────────────────────────────────────────
BACKTEST_DIAS=90
BACKTEST_CAPITAL=1000.0
# 0.04% por lado (Binance Futures Maker)
COMISION_PCT=0.0004      

# ── Notificaciones Telegram (opcional) ───────────────
# Guía: https://core.telegram.org/bots#how-do-i-create-a-bot
TELEGRAM_TOKEN=8674374105:AAFlTIlWAxwKzBOjSMTq81KlsbbZK18bMMs
TELEGRAM_CHAT_ID=-5247902210

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR

# ── Multi-Timeframe (Fase 3) ─────────────────────────────
MTF_ENABLED=false
# Timeframe alto para contexto estructural
MTF_HTF=1h
# Timeframe bajo para entrada precisa
MTF_LTF=1h              
MTF_HTF_CANDLES=200
MTF_LTF_CANDLES=100
# Puntos extra si HTF y LTF alineados
MTF_BONUS_ALINEADO=20   
# Puntos a restar si HTF opuesto a LTF
MTF_PENALTI_OPUESTO=30  

# ── WebSocket (Fase 3) ───────────────────────────────────
# false = usar polling REST clásico
WS_ENABLED=true         
# Segundos base para reconexión
WS_RECONNECT_SECS=5     
# Máximo de intentos antes de parar
WS_MAX_RECONNECTS=10    

# ── Dashboard (Opción A: VPS con nginx) ──────────────────
# No requiere variables extra, solo correr setup_dashboard.sh

# ── Dashboard (Opción B: Cloudflare Pages) ───────────────
# 1. Crear token en: https://dash.cloudflare.com/profile/api-tokens
#    Permiso requerido: "Cloudflare Pages: Edit"
# 2. Account ID en: https://dash.cloudflare.com (barra lateral)
# 3. Crear proyecto en Pages → "Direct Upload" → nombre: smc-bot
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_PROJECT_NAME=smc-bot

# TIMEZONE
TZ=America/Argentina/Buenos_Aires
